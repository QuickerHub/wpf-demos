<Window
    x:Class="CeaViewRunner.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CeaViewRunner Demo"
    Width="520"
    Height="360">
    <StackPanel Margin="16">
        <TextBlock Margin="0,0,0,12" TextWrapping="Wrap">
            演示从 CeaQuickerTools.ViewRunner 迁移的入口（需本机 Quicker 目录或设置 QUICKER_DLL_PATH 以满足 qkref.props）。
        </TextBlock>
        <Button Margin="0,0,0,8" Click="OnMessageBox3OkCancel" Content="MessageBox3md Ok/Cancel" />
        <Button Margin="0,0,0,8" Click="OnMessageBox3Show" Content="MessageBox3md show (toast)" />
        <Button Margin="0,0,0,8" Click="OnTimeWindow" Content="TimeWindow (now)" />
        <Button Click="OnGuides" Content="ShowGuidesWindow" />
    </StackPanel>
</Window>
