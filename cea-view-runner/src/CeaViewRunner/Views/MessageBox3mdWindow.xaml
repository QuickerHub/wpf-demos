<Window
    x:Class="CeaViewRunner.Views.MessageBox3mdWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entities="clr-namespace:Quicker.Public.Entities;assembly=Quicker.Public"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mdx="clr-namespace:MdXaml;assembly=MdXaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:CeaViewRunner.ViewModels"
    Title="MessageBox3mdWindow"
    Width="{Binding WindowParam.width, Mode=TwoWay}"
    Height="{Binding WindowParam.height, Mode=TwoWay}"
    MinWidth="100"
    MinHeight="50"
    MaxWidth="{Binding WindowParam.maxWidth}"
    MaxHeight="{Binding WindowParam.maxHeight}"
    d:DataContext="{d:DesignInstance Type=viewmodel:MessageBox3mdModel}"
    d:Height="200"
    d:Width="400"
    hc:WindowAttach.IsDragElement="True"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    SizeToContent="{Binding WindowParam.sizeToContent}"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="WindowContentBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.5"
                        ShadowDepth="0" />
                </Setter.Value>
            </Setter>
        </Style>
        <x:Array x:Key="DesignButtonList" Type="entities:CommonOperationItem">
            <entities:CommonOperationItem Title="确认(_S)" Data="Ok" />
        </x:Array>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        AutoReverse="False"
                        RepeatBehavior="1x"
                        Storyboard.TargetProperty="(Window.Opacity)"
                        From="0.0"
                        To="1.0"
                        Duration="0:0:0.15" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid Margin="20">
        <Border Opacity="{Binding WindowParam.opacity}" Style="{StaticResource WindowContentBorder}">
            <Image Margin="5" Source="{Binding WindowParam.backgroundImage}" />
        </Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid Margin="{Binding WindowParam.padding}" d:Margin="15,10">
                <mdx:MarkdownScrollViewer
                    Name="MdViewer"
                    VerticalAlignment="Top"
                    hc:ScrollViewerAttach.AutoHide="False"
                    xml:space="preserve"
                    Background="Transparent"
                    Markdown="{Binding MarkDown}"
                    MarkdownStyle="{StaticResource MdStyle}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </Grid>
            <WrapPanel
                Grid.Row="1"
                Margin="10"
                HorizontalAlignment="Center">
                <CheckBox IsChecked="{Binding DoNotRemind}" Visibility="{Binding ShowDoNotRemind, Converter={StaticResource Boolean2VisibilityConverter}}">
                    不再提示
                </CheckBox>
                <ItemsControl
                    x:Name="TheButtonList"
                    d:ItemsSource="{StaticResource DesignButtonList}"
                    ItemTemplate="{StaticResource SmallIconDataTemplate}"
                    ItemsPanel="{StaticResource ButtonGroupHorizontalStackItemsPanelTemplate}"
                    ItemsSource="{Binding CustomButtons}" />
            </WrapPanel>
        </Grid>
        <Button
            Width="28"
            Height="28"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,-8,-8,0"
            Background="Transparent"
            BorderThickness="0"
            Click="CloseButton_Click"
            Content="×"
            FontSize="16"
            Foreground="{DynamicResource PrimaryTextBrush}"
            ToolTip="关闭" />
    </Grid>
</Window>
