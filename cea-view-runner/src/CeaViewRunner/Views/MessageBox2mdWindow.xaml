<Window
    x:Class="CeaViewRunner.Views.MessageBox2mdWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entities="clr-namespace:Quicker.Public.Entities;assembly=Quicker.Public"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mdx="clr-namespace:MdXaml;assembly=MdXaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:CeaViewRunner.ViewModels"
    Title="{Binding Title}"
    Width="{Binding WindowParam.width, Mode=TwoWay}"
    MinWidth="100"
    MinHeight="100"
    MaxHeight="{Binding WindowParam.maxHeight, Mode=TwoWay}"
    d:DataContext="{d:DesignInstance Type=viewmodel:MessageBox2mdModel}"
    hc:WindowAttach.IsDragElement="True"
    ResizeMode="CanResize"
    ShowInTaskbar="True"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <x:Array x:Key="DesignButtonList" Type="entities:CommonOperationItem">
            <entities:CommonOperationItem Title="确认(_S)" Data="Ok" />
            <entities:CommonOperationItem Title="取消(_C)" Data="Cancel" />
        </x:Array>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <mdx:MarkdownScrollViewer
            Name="MdViewer"
            hc:ScrollViewerAttach.AutoHide="False"
            xml:space="preserve"
            FocusVisualStyle="{x:Null}"
            Markdown="{Binding MarkDown}"
            MarkdownStyle="{StaticResource MdStyle}" />
        <ItemsControl
            x:Name="TheButtonList"
            Grid.Row="1"
            Margin="10"
            HorizontalAlignment="Center"
            d:ItemsSource="{StaticResource DesignButtonList}"
            ItemTemplate="{StaticResource SmallIconDataTemplate}"
            ItemsPanel="{StaticResource ButtonGroupHorizontalStackItemsPanelTemplate}"
            ItemsSource="{Binding CustomButtons}" />
    </Grid>
</Window>
