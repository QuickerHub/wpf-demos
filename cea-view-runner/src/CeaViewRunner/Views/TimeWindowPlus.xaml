<Window
    x:Class="CeaViewRunner.Views.TimeWindowPlus"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:viewmodel="clr-namespace:CeaViewRunner.ViewModels"
    Title="TimeWindowPlus"
    Width="300"
    Height="100"
    d:DataContext="{d:DesignInstance Type=viewmodel:TimeWindowViewModel}"
    hc:WindowAttach.IsDragElement="True"
    AllowsTransparency="True"
    Background="#02FFFFFF"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid Margin="10" ToolTipService.InitialShowDelay="0" ToolTipService.Placement="Left">
        <Grid.ToolTip>
            <ToolTip>
                <TextBlock FontSize="{Binding Skin.FontSize2}" Text="{Binding Tooltip}" />
            </ToolTip>
        </Grid.ToolTip>
        <Border Background="{Binding Skin.Background}" CornerRadius="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" />
            </Border.Effect>
        </Border>
        <Grid Margin="15,10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="ClockBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                d:Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:HH:mm:ss}'}"
                FontFamily="{Binding Skin.FontFamily}"
                FontSize="{Binding Skin.FontSize1}"
                Foreground="{Binding Skin.Foreground}"
                Text="{Binding ClockText}" />
            <TextBlock
                x:Name="DayBlock"
                Grid.Row="1"
                HorizontalAlignment="Right"
                FontFamily="{Binding Skin.FontFamily}"
                FontSize="{Binding Skin.FontSize2}"
                Foreground="{Binding Skin.Foreground}"
                Text="{Binding DayText}"
                TextAlignment="Right"
                Visibility="{Binding ShowDay, Converter={StaticResource Boolean2VisibilityConverter}}" />
        </Grid>
    </Grid>
</Window>
