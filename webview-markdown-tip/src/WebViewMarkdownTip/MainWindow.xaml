<hc:Window
    x:Class="WebViewMarkdownTip.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WebViewMarkdownTip"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="{Binding ViewModel.TitleText}"
    Width="560"
    Height="520"
    MinWidth="400"
    MinHeight="320"
    d:DataContext="{d:DesignInstance local:MainWindow,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="520"
    d:DesignWidth="560"
    Background="{DynamicResource DefaultWindowBackgroundBrush}"
    Foreground="{DynamicResource PrimaryTextBrush}"
    ResizeMode="CanResize"
    ShowNonClientArea="False"
    ShowTitle="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </hc:Window.Resources>
    <hc:Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding ViewModel.CloseWindowCommand}" />
    </hc:Window.InputBindings>
    <Grid Background="{DynamicResource RegionBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <wv2:WebView2
            x:Name="WebViewControl"
            Grid.Row="0"
            VerticalAlignment="Stretch" />
        <Border
            Grid.Row="1"
            Padding="10,8,10,10"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{Binding ViewModel.FooterHasButtons, Converter={StaticResource BoolToVisibilityConverter}}">
            <WrapPanel HorizontalAlignment="Center">
                <ItemsControl ItemsSource="{Binding ViewModel.FooterButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:MarkdownTipWebButton}">
                            <Button
                                MinWidth="72"
                                Margin="4,4"
                                Padding="10,6"
                                Command="{Binding DataContext.ViewModel.TipFooterButtonCommand, RelativeSource={RelativeSource AncestorType=hc:Window}}"
                                CommandParameter="{Binding Data}"
                                Content="{Binding Title}"
                                ToolTip="{Binding Description}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </Border>
    </Grid>
</hc:Window>
